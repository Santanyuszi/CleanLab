; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CleanLab"
config/description="Technical cleanliness laboratory simulation"
config/version="1.1.0"
run/main_scene="res://scenes/main/IntroSplash.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/app_icon/cleanlab_app_icon_512.png"

[autoload]

GameManager="*res://scripts/autoload/GameManager.gd"
TouchInput="*res://scripts/autoload/TouchInput.gd"
PlatformServices="*res://scripts/autoload/PlatformServices.gd"
AchievementManager="*res://scripts/autoload/AchievementManager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

tap={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":1,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":true,"double_click":false,"script":null)
, Object(InputEventScreenTouch,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"index":0,"position":Vector2(0, 0),"canceled":false,"pressed":true,"double_tap":false,"script":null)
]
}

[layer_names]

2d_physics/layer_1="world"
2d_physics/layer_2="worker"
2d_physics/layer_3="interactable"

[rendering]

renderer/rendering_method="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
