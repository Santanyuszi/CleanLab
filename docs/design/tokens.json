{
  "meta": {
    "name": "CLEANLAB UI Design System",
    "version": "1.0",
    "target_resolution": "1920x1080",
    "grid": {
      "columns": 12,
      "outer_margin": 40,
      "spacing": [4, 8, 16, 24, 32, 48, 64]
    }
  },
  "colors": {
    "background": {
      "main": "#040B12",
      "alternative_dark": "#08111A",
      "panel": "#0B1621",
      "panel_hover": "#122130"
    },
    "accent": {
      "primary": "#00D7D0",
      "bright": "#29FFF8",
      "selection": "#00FFC8",
      "success": "#28E07D",
      "warning": "#FFB340",
      "danger": "#FF5B5B"
    },
    "text": {
      "primary": "#F7FAFC",
      "secondary": "#B9C7D3",
      "disabled": "#667381"
    },
    "glass": {
      "background": "rgba(15,25,35,0.65)",
      "border": "rgba(255,255,255,0.08)"
    }
  },
  "typography": {
    "font": "DM Sans",
    "fallback": "Inter",
    "logo": { "size": 64, "weight": 700, "letter_spacing_percent": -2 },
    "stat_label": { "size": 12, "weight": 500 },
    "stat_value": { "size": 32, "weight": 700 },
    "panel_header": { "size": 18, "weight": 600 },
    "body": { "size": 15, "weight": 400, "line_height": 22 },
    "button": { "size": 18, "weight": 600 }
  },
  "layout": {
    "top_status_bar": { "height": 80, "radius": 16, "section_width": 220 },
    "left_task_panel": { "width": 260, "radius": 20, "task_card_height": 70 },
    "right_orders_panel": { "width": 280, "order_card_height": 140, "radius": 18 },
    "shipping_panel": { "height": 300, "button_width": 220, "button_height": 60, "button_radius": 14 },
    "bottom_navigation": { "height": 90, "button_width": 220, "button_height": 70, "button_radius": 18 },
    "station_label": { "width": 180, "height": 72, "radius": 14 }
  },
  "animation": {
    "button_hover_ms": 150,
    "selection_ms": 200,
    "panel_open_ms": 250,
    "station_completion_pulse_ms": 500
  }
}
